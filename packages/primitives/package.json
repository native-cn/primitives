{
  "name": "@native-cn/primitives",
  "version": "0.1.0",
  "description": "shadcn/ui primitives for React Native — beautifully designed, accessible, and customizable.",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./dist-types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist-types/index.d.ts",
      "default": "./src/index.ts"
    },
    "./ui/*": {
      "types": "./dist-types/ui/*.d.ts",
      "default": "./src/ui/*.tsx"
    },
    "./lib/*": {
      "types": "./dist-types/lib/*.d.ts",
      "default": "./src/lib/*.ts"
    },
    "./registry": "./registry/registry.json",
    "./tailwind": "./src/tailwind-preset.js",
    "./package.json": "./package.json"
  },
  "files": [
    "src/",
    "dist-types/",
    "registry/"
  ],
  "scripts": {
    "dev": "tsc --noEmit -w",
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist-types",
    "lint": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "keywords": [
    "react-native",
    "shadcn",
    "ui-components",
    "nativewind",
    "native-cn"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/native-cn/primitives.git",
    "directory": "packages/primitives"
  },
  "homepage": "https://github.com/native-cn/primitives",
  "bugs": {
    "url": "https://github.com/native-cn/primitives/issues"
  },
  "license": "MIT",
  "peerDependencies": {
    "nativewind": "^4.0.0",
    "react": "^18.3.0 || ^19.0.0",
    "react-native": "^0.72.0 || ^0.73.0 || ^0.74.0 || ^0.75.0 || ^0.76.0",
    "tailwindcss": "^3.4.0"
  },
  "dependencies": {
    "clsx": "^2.1.0",
    "react-native-svg": "^15.15.5",
    "tailwind-merge": "^2.4.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "nativewind": "^4.0.0",
    "react": "^19.0.0",
    "react-native": "^0.76.0",
    "tailwindcss": "^3.4.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
