{
  "name": "native-cn",
  "private": true,
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "format": "prettier --check \"**/*.{ts,tsx,md}\"",
    "version:primitives": "pnpm --filter @native-cn/primitives version",
    "publish:primitives": "pnpm --filter @native-cn/primitives publish"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "prettier": "^3.2.0",
    "typescript": "^5.5.0"
  }
}
